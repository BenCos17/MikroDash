# Required: set these three values
ROUTER_HOST=192.168.88.1
ROUTER_USER=mikrodash
ROUTER_PASS=change-me

# Recommended
DEFAULT_IF=ether1

# Optional core settings
PORT=3081
ROUTER_PORT=8728
ROUTER_TLS=false
ROUTER_TLS_INSECURE=false
HISTORY_MINUTES=30
PING_TARGET=1.1.1.1

# uncomment the stuff below to allow multipe devices to be monitored. You can have as many as you like, just follow the pattern.
# Optional: monitor multiple routers (easy line-by-line banks)
# Bank format: ROUTER_<n>_HOST/USER/PASS are required for each router.
# Optional per-bank: ID, NAME, PORT, TLS, TLS_INSECURE, DEFAULT_IF, DEBUG.
# ROUTER_1_ID=home
# ROUTER_1_NAME=Home Router
# ROUTER_1_HOST=192.168.88.1
# ROUTER_1_USER=mikrodash
# ROUTER_1_PASS=secret
# ROUTER_1_PORT=8728
# ROUTER_1_TLS=false
# ROUTER_1_DEFAULT_IF=ether1
#
# ROUTER_2_ID=lab
# ROUTER_2_NAME=Lab Router
# ROUTER_2_HOST=10.0.0.1
# ROUTER_2_USER=mikrodash
# ROUTER_2_PASS=secret
# ROUTER_2_PORT=8729
# ROUTER_2_TLS=true
# ROUTER_2_TLS_INSECURE=true
# ROUTER_2_DEFAULT_IF=wan

# Legacy alternative: single-line JSON
# Used only when no ROUTER_<n> banks are set.
# ROUTERS_JSON=[{"id":"home","name":"Home Router","host":"192.168.88.1","port":8728,"tls":false,"username":"mikrodash","password":"secret","defaultIf":"ether1"},{"id":"lab","name":"Lab Router","host":"10.0.0.1","port":8729,"tls":true,"tlsInsecure":true,"username":"mikrodash","password":"secret","defaultIf":"wan"}]

# Optional advanced tuning (uncomment only if needed)
# CONNS_POLL_MS=3000
# KIDS_POLL_MS=3000
# DHCP_POLL_MS=15000
# LEASES_POLL_MS=15000
# ARP_POLL_MS=30000
# SYSTEM_POLL_MS=3000
# WIRELESS_POLL_MS=5000
# VPN_POLL_MS=10000
# FIREWALL_POLL_MS=10000
# IFSTATUS_POLL_MS=5000
# PING_POLL_MS=10000
# TOP_N=10
# TOP_TALKERS_N=5
# FIREWALL_TOP_N=15
# ROS_DEBUG=false
